{
	"compilerOptions": {
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"types": ["bun"],
		"strict": true,
		"skipLibCheck": true,
		"paths": {
			"@server/*": ["./server/*"],
			"@web/*": ["./web/*"],
			"@shared/*": ["./shared/*"]
		}
	},
	"exclude": ["web"]
}
